    <title>Software Engineering</title>
    <duration>10 Weeks</duration>
    <instructor>Prof. Rachel Kim</instructor>
    <description>Understand the software development lifecycle, Agile methodologies, version control, and team collaboration practices.</description>
    <image>https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=400&amp;q=80</image>
    <lessons>
      <lesson>Software Development Life Cycle</lesson>
      <lesson>Agile and Scrum Methodology</lesson>
      <lesson>Requirements Engineering</lesson>
      <lesson>UML Diagrams</lesson>
      <lesson>Version Control with Git</lesson>
      <lesson>Code Review and Refactoring</lesson>
      <lesson>Testing Strategies</lesson>
      <lesson>Deployment and DevOps Overview</lesson>
    </lessons>
  </course>

